# =========================================================================
# CyberVerse AI — Backend Environment Configuration Example
# =========================================================================
# Copy this file to '.env' and fill in your actual credentials.
# NEVER commit the actual '.env' file to version control.

# ----------------- Environment Mode -----------------
# Environment type: 'development' or 'production'.
# In 'production' mode, strict validations are enforced:
# - A custom SECRET_KEY is MANDATORY (dynamic secure fallback is disabled).
# - The active LLM provider's API key is MANDATORY.
# - Defaults to 'development' if not specified.
APP_ENV=development

# ----------------- Application Settings -----------------
HOST=0.0.0.0
PORT=8090

# Cryptographic Secret Key for token signing and encryption.
# Generate a secure one via: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ----------------- CORS Origins Settings -----------------
# Comma-separated list of origins allowed to access the API.
# Examples:
#
# 1. Single Origin:
# CORS_ORIGINS=http://localhost:3000
#
# 2. Multiple Origins:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
#
# 3. Wildcard:
# CORS_ORIGINS=*
#
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------- Database Settings -----------------
# Default is local SQLite. In production, highly recommend PostgreSQL/MySQL.
# Example PostgreSQL: postgresql://db_user:db_password@localhost:5432/cyberverse
DATABASE_URL=sqlite:///./instance/cyberverse.db

# ----------------- Redis / Celery -----------------
REDIS_URL=redis://localhost:6379/0
CELERY_QUEUE_NAME=celery
CELERY_TASK_TIME_LIMIT_SECONDS=1800
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=1500

# ----------------- Rate Limiting -----------------
# Distributed sliding-window limits.
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REDIS_REQUIRED=false

# ----------------- Scan Runtime -----------------
# Temporary scan workspaces are deleted after scan completion.
SCAN_WORKSPACE_ROOT=
MAX_UPLOAD_BYTES=5242880
GIT_CLONE_TIMEOUT_SECONDS=120
GIT_CLONE_DEPTH=1

# ----------------- LLM Provider Configuration -----------------
# Preferred provider: 'groq', 'anthropic', 'openai', or 'ollama'
PREFERRED_LLM_PROVIDER=groq

# --- Groq (Primary Model Provider) ---
# Active Groq API Key
GROQ_API_KEY=
# Target Groq Model (e.g. llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Ollama (Local LLM) ---
OLLAMA_API_BASE=http://localhost:11434/v1
OLLAMA_MODEL=llama3
