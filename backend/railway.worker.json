{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "celery -A app.core.celery:celery_app worker --loglevel=info --concurrency=4 --prefetch-multiplier=1",
    "restartPolicyType": "ON_FAILURE"
  },
  "env": {
    "SCAN_WORKSPACE_ROOT": "/tmp/cyberverse_scans"
  }
}